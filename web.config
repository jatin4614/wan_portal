<?xml version="1.0" encoding="utf-8"?>
<!--
  WAN Portal - IIS configuration for HttpPlatformHandler.

  This file makes IIS launch the app's own Python + Waitress process and
  reverse-proxy every request to it. It is required: without it IIS serves the
  folder as static files and every dynamic URL returns 404.

  RUN setup_wanportal_iis.ps1 -- it rewrites this file in place with ABSOLUTE
  paths and the correct URL_PREFIX before creating the IIS application. That is
  the supported deploy path and you should not need to touch anything here.

  The '.'-relative paths below are only a readable placeholder. IMPORTANT: IIS
  HttpPlatformHandler resolves a leading '.' against the PARENT SITE's root, NOT
  this application's folder. So when the app is mounted as a sub-application
  (e.g. /wanportal under the 'comn report' site), these relative paths will NOT
  resolve and you would get HTTP 502.5 -- which is exactly why the script bakes
  in absolute paths. Only edit-and-use this file by hand if you host the app at
  the ROOT of its own dedicated site (then site root == app folder and '.' works).

  IMPORTANT - URL_PREFIX must equal the IIS application alias, with a leading
  slash. This app is mounted at /wanportal, so URL_PREFIX = /wanportal. If you
  mount it under a different alias, change URL_PREFIX to match. If you host it at
  the ROOT of its own site (no alias), set URL_PREFIX to an empty string.
-->
<configuration>
  <system.webServer>

    <!-- Route every request to the Python (Waitress) process. -->
    <handlers>
      <remove name="httpPlatformHandler" />
      <add name="httpPlatformHandler" path="*" verb="*"
           modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>

    <!--
      HttpPlatformHandler starts the process and injects HTTP_PLATFORM_PORT,
      which serve.py binds Waitress to. stdout/stderr are captured under .\logs
      as stdout_<pid>_<timestamp>.log for troubleshooting.
    -->
    <httpPlatform stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  startupTimeLimit="120"
                  startupRetryCount="3"
                  requestTimeout="00:10:00"
                  processPath=".\venv\Scripts\python.exe"
                  arguments=".\serve.py">
      <environmentVariables>
        <!-- Must match the IIS application alias (leading slash). -->
        <environmentVariable name="URL_PREFIX"      value="/wanportal" />
        <!-- Upload cap in MB (0 = unlimited). Mirrors the app default. -->
        <environmentVariable name="MAX_UPLOAD_MB"   value="16384" />
        <!-- Unbuffered stdout so the startup log appears immediately. -->
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
      </environmentVariables>
    </httpPlatform>

    <!--
      IIS caps request bodies at ~30 MB by default, which would 404.13 the tile
      and Excel uploads. Raise it to the maximum IIS allows (~4 GB). Uploads
      larger than 4 GB cannot pass through IIS regardless of the app's cap.
    -->
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="4294967295" />
      </requestFiltering>
    </security>

    <!-- Don't let IIS try to serve/redirect directory requests itself. -->
    <defaultDocument enabled="false" />
    <directoryBrowse enabled="false" />

  </system.webServer>
</configuration>
